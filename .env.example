# WordPress Backend URL (headless CMS)
NEXT_PUBLIC_WORDPRESS_API_URL=https://goodmove.cz/wp-json/wp/v2

# Optional: WPGraphQL endpoint (for more efficient queries)
# NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL=https://goodmove.cz/graphql

# Site URL (Next.js frontend)
NEXT_PUBLIC_SITE_URL=https://goodmove.cz

# Contact Form 7 REST API endpoint (for contact form)
NEXT_PUBLIC_CF7_API_URL=https://goodmove.cz/wp-json/contact-form-7/v1/contact-forms

# Active theme variant: "default" | "dark" | "organic"
NEXT_PUBLIC_THEME=default

# Revalidation secret (for on-demand ISR when WordPress posts update)
REVALIDATE_SECRET=your_secret_here
